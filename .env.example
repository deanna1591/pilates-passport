# ════════════════════════════════════════════════════════════════
# PILATES PASSPORT — Environment Variables
# ════════════════════════════════════════════════════════════════
#
# HOW TO USE:
#   1. Copy this file: cp .env.example .env.local
#   2. Fill in your real values below
#   3. NEVER commit .env.local to git (it's in .gitignore)
#
# FOR NETLIFY DEPLOYMENT:
#   Add these in: Site → Environment variables
#   Both variables must be set before deploying or the build will fail.
#
# ════════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED) ─────────────────────────────────────────
# Find at: https://supabase.com/dashboard → your project → Settings → API

# Your project URL — looks like: https://abcdefghijklm.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your anon/public key — a long JWT starting with eyJ...
# This is safe to expose in the browser. It is NOT your service_role key.
VITE_SUPABASE_ANON_KEY=eyJyour-anon-key-here

# ── App config (OPTIONAL) ───────────────────────────────────────
VITE_APP_NAME=Pilates Passport
VITE_APP_VERSION=1.0.0

# ── Feature flags (OPTIONAL — defaults to true) ─────────────────
# Set to "false" to disable features during development
VITE_ENABLE_GPS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_HEALTHKIT=true

# ════════════════════════════════════════════════════════════════
# SECURITY NOTES:
#   - VITE_ prefix means these variables are included in the browser bundle
#   - Only use the anon/public key here, NEVER the service_role key
#   - The service_role key bypasses all RLS policies — keep it server-side only
# ════════════════════════════════════════════════════════════════

# ── Google Places API (REQUIRED for studio search + nearby) ─────────────────
# This key is SERVER-SIDE only — set it in Netlify environment variables.
# Do NOT prefix with VITE_ — it must never be exposed to the browser.
#
# How to get your key:
#   1. Go to https://console.cloud.google.com
#   2. Create a project → Enable "Places API"
#   3. Go to Credentials → Create API Key
#   4. Restrict the key to "Places API" only
#   5. Add to Netlify: Site → Environment variables → GOOGLE_PLACES_API_KEY
#
# This key goes in Netlify env vars, NOT in .env.local
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# ── Google Maps Embed API (client-side, safe to expose) ─────────────────────
# This is a SEPARATE key from GOOGLE_PLACES_API_KEY.
# Restrict it in Google Cloud Console to:
#   - Maps Embed API only
#   - HTTP referrers: your-site.netlify.app/*
# Add as VITE_GOOGLE_MAPS_KEY in Netlify environment variables.
VITE_GOOGLE_MAPS_KEY=your-google-maps-embed-key-here
